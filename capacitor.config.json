{
  "appId": "com.planrun.app",
  "appName": "planRUN",
  "webDir": "dist",
  "android": {
    "allowMixedContent": true,
    "captureInput": false,
    "adjustMarginsForEdgeToEdge": "disable"
  },
  "plugins": {
    "Keyboard": {
      "resizeOnFullScreen": false
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  }
}
