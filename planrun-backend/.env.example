# Копируйте в .env и заполните значения

# База данных
DB_HOST=localhost
DB_NAME=sv
DB_USER=root
DB_PASSWORD=
# PHPUnit может временно подменить DB_NAME на отдельную базу:
# PLANRUN_PHPUNIT_DB_NAME=sv_test

# JWT
JWT_SECRET_KEY=replace-with-a-random-secret-at-least-32-characters-long
# Access token: срок жизни в днях (по умолчанию 1 день)
# JWT_ACCESS_EXPIRATION_DAYS=1
# Refresh token: sliding expiration (продление при каждом использовании)
# JWT_REFRESH_SLIDING_DAYS=30 — продлевать на 30 дней при каждом refresh
# JWT_REFRESH_MAX_AGE_DAYS=90 — верхняя граница
# JWT_REFRESH_INITIAL_DAYS=30 — срок при создании (логин)

# URL приложения (для ссылок в письмах)
APP_URL=https://planrun.ru

# Почта для сброса пароля (SMTP)
# Если MAIL_HOST и MAIL_USERNAME пустые — используется PHP mail()
# Roundcube на том же сервере → MAIL_HOST=localhost; иначе — хост из настроек SMTP Roundcube
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=info@planrun.ru
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@planrun.ru
MAIL_FROM_NAME=PlanRun
# Опционально: отключить проверку SSL (только для самоподписанных сертификатов на своём сервере)
# MAIL_VERIFY_PEER=0

# Чат: OpenAI-compatible endpoint (DeepSeek / llama-server / vllm / etc.)
LLM_PROVIDER=deepseek
LLM_CHAT_BASE_URL=https://api.deepseek.com
LLM_CHAT_MODEL=deepseek-v4-flash
# LLM_CHAT_API_KEY can be omitted when PLAN_LLM_API_KEY or DEEPSEEK_API_KEY is set.
# LLM_CHAT_API_KEY=
# Optional comma/space/newline separated pool. Gateway randomly spreads requests across keys.
# LLM_CHAT_API_KEYS=
CHAT_HISTORY_MESSAGES_LIMIT=100
CHAT_MAX_TOKENS=4096
LLM_MAX_RETRIES=1
# HTTP retries around a single provider call. Queue retries still happen at job level.
# LLM_GATEWAY_MAX_ATTEMPTS=2
# LLM_GATEWAY_RETRY_BASE_DELAY_MS=700
# LLM_GATEWAY_RETRY_MAX_DELAY_MS=8000
# Global DB-backed concurrency limiter. 0 disables a limit.
# LLM_GATEWAY_GLOBAL_MAX_CONCURRENT=8
# LLM_GATEWAY_LIMIT_WAIT_SECONDS=15
# LLM_GATEWAY_LIMIT_TTL_SECONDS=0
# LLM_CHAT_MAX_CONCURRENT=5
# LLM_CHAT_LIMIT_WAIT_SECONDS=8
# LLM_QUEUE_RETRY_DELAY_SECONDS=60
# LLM_QUEUE_RATE_LIMIT_RETRY_SECONDS=120
# LLM_QUEUE_OVERLOAD_RETRY_SECONDS=90
# Суммаризация: при количестве сообщений > порога старые заменяются на summary
CHAT_SUMMARIZE_ENABLED=1
CHAT_SUMMARIZE_THRESHOLD=35
CHAT_RECENT_MESSAGES=15
CHAT_SEARCH_HISTORY=1
CHAT_RAG_ENABLED=0
# Tools (function calling): get_plan, get_workouts, get_day_details, update_training_day и др.
CHAT_TOOLS_ENABLED=1
# 0 = напрямую в LLM_CHAT_BASE_URL. 1 = через PlanRun AI orchestration layer (/api/v1/chat)
# Если 1, tools в backend сейчас отключаются.
CHAT_USE_PLANRUN_AI=0
# При ошибке прямого LLM можно временно пробовать PlanRun AI /chat
CHAT_FALLBACK_TO_PLANRUN_AI=0
CHAT_MEMORY_ENABLED=1

# Планогенерация (production: только PLAN_GENERATION_MODE=llm_planner на DeepSeek V4).
# См. docs/PLANS-AI-V2.md и .cursor/rules/plans-ai-v2.mdc.
PLAN_GENERATION_MODE=llm_planner
# Phase A.3 (PR2): одна модель для планировщика. Раньше — отдельные planner/detail/repair, унифицировано.
# PLAN_LLM_MODEL=deepseek-chat
# Phase A.2 (PR2): убрана staged стратегия — single_pass всегда.
# PLAN_LLM_PLANNER_THINKING=0
# PLAN_LLM_REQUEST_MAX_ATTEMPTS=2
# Phase C.1 (PR5): авто-эскалация на deepseek-reasoner для сложных сценариев
# (≥2 risk-флагов одновременно: return_after_injury, b_race_before_a_race, illness/pain_protective,
#  pregnant_or_postpartum, goal_realism.severity=major). Auto=1 включает это поведение.
# PLAN_LLM_REASONER_MODEL=deepseek-reasoner
# PLAN_LLM_AUTO_REASONER=1
# PLAN_LLM_REASONER_TIMEOUT_SECONDS=360
# Phase D.1 (PR6): observability layer для plan generation. Запись успешных и неудавшихся
# генераций в ai_plan_generation_events (миграция scripts/migrate_ai_plan_generation_events.php).
# Используется admin-эндпоинтами admin_ai_plan_metrics / admin_ai_plan_events.
# PLAN_AI_EVENT_LOG_ENABLED=1
# Quality gate / safety (philosophy: trust the model + injury-only guardrails, см. docs/PLANS-AI-V2.md раздел 0a):
# PLAN_LLM_QUALITY_GATE_MODE=auto
# PLAN_LLM_HARD_SAFETY_REPAIRS=1
# PLAN_LLM_RACE_WEEK_CAP_REPAIRS=1
# PLANRUN_AI_STATE_SCENARIO=1
# PR3 / Phase B.1+B.2: recent_compliance (4 ISO-недели) и recent_workouts_detailed (14 дней с RPE/HR/pace) в FACTS_JSON
# PLANRUN_AI_STATE_RECENT_CONTEXT=1
# PLAN_LLM_MAX_CONCURRENT=3
# PLAN_LLM_LIMIT_WAIT_SECONDS=45
# Phase A.1 (PR2): skeleton-first отключён в production. Код — в planrun_ai/_legacy/skeleton/ для diagnostic скриптов.
# USE_SKELETON_GENERATOR — DEPRECATED, не использовать. Включение приводит к RuntimeException в processViaSkeleton.
# Optional dedicated LLM for plan enrichment/review. Keeps chat on LLM_CHAT_* until switched separately.
# PLAN_LLM_PROVIDER=deepseek
# PLAN_LLM_BASE_URL=https://api.deepseek.com
# PLAN_LLM_API_KEY=
# Optional comma/space/newline separated pool for parallel plan workers.
# PLAN_LLM_API_KEYS=
# PLAN_LLM_ENRICHER_MODEL=deepseek-v4-flash
# PLAN_LLM_REVIEWER_MODEL=deepseek-v4-pro
# PLAN_LLM_ENRICHER_MAX_TOKENS=8192
# PLAN_LLM_REVIEWER_MAX_TOKENS=16384
# PLAN_LLM_ENRICHER_TIMEOUT_SECONDS=240
# PLAN_LLM_REVIEWER_TIMEOUT_SECONDS=300
# PLAN_LLM_CONNECT_TIMEOUT_SECONDS=10
# Optional LLM checks should fail fast; algorithmic quality gate remains authoritative.
# LLM_REVIEWER_TIMEOUT_SECONDS=45
# LLM_REVIEWER_CONNECT_TIMEOUT_SECONDS=5
# LLM_REVIEWER_MAX_TOKENS=768
# PLAN_REVIEW_LLM_TIMEOUT_SECONDS=45
# PLAN_REVIEW_LLM_CONNECT_TIMEOUT_SECONDS=5
# PLAN_REVIEW_LLM_MAX_TOKENS=700
# Через сколько секунд running job считается зависшим и возвращается/закрывается worker-ом
# PLAN_GENERATION_RUNNING_TIMEOUT_SECONDS=1800

# Proactive coach
PROACTIVE_COACH_ENABLED=1
POST_WORKOUT_FOLLOWUPS_ENABLED=1
POST_WORKOUT_FOLLOWUPS_LIMIT=50
POST_WORKOUT_FOLLOWUP_DELAY_MINUTES=15
POST_WORKOUT_FOLLOWUP_MAX_AGE_HOURS=8
POST_WORKOUT_FOLLOWUP_REPLY_WINDOW_HOURS=36
POST_WORKOUT_ANALYSIS_ENABLED=1
# POST_WORKOUT_ANALYSIS_TIMEOUT_SECONDS=25
# POST_WORKOUT_ANALYSIS_MAX_TOKENS=650

# Интеграции: Huawei Health Kit
# HUAWEI_HEALTH_CLIENT_ID=
# HUAWEI_HEALTH_CLIENT_SECRET=
# HUAWEI_HEALTH_REDIRECT_URI=https://your-domain.com/api/oauth_callback.php?provider=huawei
# HUAWEI_HEALTH_SCOPES=https://www.huawei.com/healthkit/activity.read https://www.huawei.com/healthkit/historydata.open.month

# Интеграции: Polar AccessLink
# POLAR_CLIENT_ID=
# POLAR_CLIENT_SECRET=
# POLAR_REDIRECT_URI=https://your-domain.com/api/oauth_callback.php?provider=polar
# Регистрация: https://admin.polaraccesslink.com
# Webhook (автоимпорт тренировок, событие EXERCISE):
# POLAR_WEBHOOK_CALLBACK_URL=https://your-domain.com/api/polar_webhook.php
# POLAR_WEBHOOK_SIGNATURE_SECRET= — опционально; иначе секрет в planrun-backend/storage/polar_webhook_secret.txt после php scripts/polar_register_webhook.php
# Cron (проверка webhook): 0 4 * * * php .../scripts/polar_webhook_health.php

# Интеграции: Garmin Connect Developer Program (нужна заявка: https://developer.garmin.com/gc-developer-program/activity-api/)
# OAuth 2.0 PKCE; Wellness REST — путь и метод см. в документации к вашему проекту в портале Garmin.
# GARMIN_CLIENT_ID=
# GARMIN_CLIENT_SECRET=
# GARMIN_REDIRECT_URI=https://your-domain.com/api/oauth_callback.php?provider=garmin
# GARMIN_OAUTH_SCOPES= — scope из портала Garmin (через пробел)
# GARMIN_OAUTH_AUTH_URL=https://connect.garmin.com/oauth2Confirm
# GARMIN_OAUTH_TOKEN_URL=https://diauth.garmin.com/di-oauth2-service/oauth/token
# GARMIN_WELLNESS_API_BASE=https://apis.garmin.com/wellness-api/rest
# GARMIN_ACTIVITY_FETCH_PATH=activityDetailsSummary — или путь из вашей документации
# GARMIN_ACTIVITY_FETCH_METHOD=GET — или POST, если требует API

# Интеграции: COROS Training Hub / Partner API (заявка: support.coros.com → Submit an API Application)
# После одобрения заполните URL и пути из API Reference Guide.
# COROS_CLIENT_ID=
# COROS_CLIENT_SECRET=
# COROS_REDIRECT_URI=https://your-domain.com/api/oauth_callback.php?provider=coros
# COROS_OAUTH_AUTH_URL=
# COROS_OAUTH_TOKEN_URL=
# COROS_OAUTH_SCOPES=
# COROS_OAUTH_USE_PKCE=0 — 1 если COROS требует PKCE
# COROS_TOKEN_CLIENT_AUTH=body — или basic (Authorization: Basic)
# COROS_API_BASE=
# COROS_ACTIVITY_FETCH_PATH=
# COROS_ACTIVITY_FETCH_METHOD=GET
# Доп. query/body-параметры к запросу активностей (JSON-объект):
# COROS_ACTIVITY_EXTRA_QUERY_JSON=
# Заголовок авторизации API: по умолчанию Authorization + Bearer; для других схем:
# COROS_API_ACCESS_HEADER=Authorization
# COROS_API_ACCESS_PREFIX="Bearer "
# Push (Workout Summary Data Push): endpoint api/coros_workout_push.php
# COROS_PUSH_SECRET= — если задан, POST должен содержать заголовок X-PlanRun-Coros-Secret
# COROS_PUSH_EXTERNAL_ID_KEYS=openId,open_id,userId,user_id,sub

# Интеграции: Strava API
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REDIRECT_URI=https://your-domain.com/api/oauth_callback.php?provider=strava
# STRAVA_PROXY= — опционально, для обхода блокировок (http://host:port или socks5://host:port)
# Webhook (автоматический импорт тренировок):
# STRAVA_WEBHOOK_CALLBACK_URL=https://your-domain.com/api/strava_webhook.php
# STRAVA_WEBHOOK_VERIFY_TOKEN=planrun_verify — произвольная строка для верификации
# Cron: проверка Strava каждые 4 ч (токены живут ~6 ч): 0 */4 * * * php .../scripts/strava_daily_health_check.php

# Telegram Login / OIDC
# В BotFather -> Bot Settings -> Web Login добавьте:
# - https://your-domain.com
# - https://your-domain.com/api/telegram_login_callback.php
# TELEGRAM_LOGIN_CLIENT_ID=
# TELEGRAM_LOGIN_CLIENT_SECRET=
# TELEGRAM_LOGIN_REDIRECT_URI=https://your-domain.com/api/telegram_login_callback.php
# TELEGRAM_LOGIN_SCOPES=openid profile telegram:bot_access
# Опционально: если хотите, чтобы после логина бот сразу писал welcome-сообщение
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=PlanRunBot
# Прокси для api.telegram.org и oauth.telegram.org (http://host:port или socks5://host:port)
# TELEGRAM_PROXY=
# Секрет для webhook-internal (прокси на VPS в EU). Тот же значение — в .env на VPS.
# WEBHOOK_PROXY_SECRET=

# Push-уведомления (Firebase FCM)
# Путь к JSON сервисного аккаунта Firebase (Project Settings → Service Accounts → Generate new private key)
# FIREBASE_CREDENTIALS=config/firebase-credentials.json
# Или содержимое JSON в одной строке (для Docker/CI):
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Static maps для карточек шаринга тренировки
# Сначала будет использован Mapbox, если есть токен. Если его нет — MapTiler.
# MAPBOX_ACCESS_TOKEN=
# MAPBOX_STATIC_STYLE=mapbox/light-v11
# MapTiler Static Maps по их документации требует API key и paid plan.
# MAPTILER_API_KEY=
# MAPTILER_STATIC_STYLE=streets-v2

# RAG и генерация планов: PlanRun AI (legacy orchestration layer)
PLANRUN_AI_API_URL=http://127.0.0.1:8000/api/v1/generate-plan
# Актуальная production-схема:
# - DeepSeek API (https://api.deepseek.com) -> чат и планогенерация
# - (embeddings если нужны — через отдельный сервис)
# - planrun-ai :8000 -> RAG + orchestration (используется чатом для retrieve-knowledge)
# RAG для чата (опционально): по умолчанию выводится из PLANRUN_AI_API_URL
# RAG_RETRIEVE_URL=http://127.0.0.1:8000/api/v1/retrieve-knowledge

# AI runtime / observability
# AI_OBSERVABILITY_ENABLED=1

# Post-workout recovery check-in
# POST_WORKOUT_FOLLOWUP_DELAY_MINUTES=15
# POST_WORKOUT_FOLLOWUP_MAX_AGE_HOURS=8
# POST_WORKOUT_FOLLOWUP_REPLY_WINDOW_HOURS=36
# POST_WORKOUT_FOLLOWUP_SNOOZE_EVENING_HOUR=19
# POST_WORKOUT_FOLLOWUP_SNOOZE_TOMORROW_HOUR=9
